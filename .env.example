# ─── Binance API ───
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ─── AI Provider (OpenRouter) ───
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# ─── Telegram (Notifications) ───
TELEGRAM_TOKEN=123456789:ABCDEF...
TELEGRAM_CHAT_ID=123456789

# ─── Strategy AI (Python Container) ───
# off = ไม่ใช้ Python (TA อย่างเดียว)
# ml  = ใช้ ML model ใน Python (ไม่เสีย AI credit)
# full = ML + LLM สำหรับ edge case (เสีย credit เฉพาะกรณีไม่ชัวร์)
STRATEGY_AI_MODE=off
STRATEGY_AI_URL=http://strategy-ai:8000
STRATEGY_AI_CONFIDENCE_THRESHOLD=0.70

# ─── Server ───
PORT=4001
NODE_ENV=production
